{
  "name": "witty-games",
  "version": "1.0.0",
  "description": "Game Center Manager",
  "main": "main.js",
  "author": "Witty Styzes & Games",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },

  "build": {
    "appId": "com.witty.games",
    "productName": "Witty Styzes & Games",

    "asar": true,

    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },

  "dependencies": {
    "sqlite3": "^5.1.6"
  },

  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}