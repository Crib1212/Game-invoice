{
  "name": "game-center-pro",
  "version": "1.0.0",
  "main": "main.js",
  "author": "Game Center Pro",
  "description": "Game Center POS System",
  "scripts": {
    "start": "electron .",
    "package": "electron-packager . GameCenterPro --platform=win32 --arch=x64 --out=dist --overwrite",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.gamecenter.pos",
    "productName": "GameCenterPro",
    "asar": false,
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "sqlite3": "^5.1.6"
  }
}
