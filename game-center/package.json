{
  "name": "witty-games",
  "version": "1.0.0",
  "description": "Game Center POS System",
  "main": "main.js",
  "author": "Witty Games",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
     "package": "electron-packager . GameCenterPro --platform=win32 --arch=x64 --out=dist --overwrite"
  },
  "build": {
    "appId": "com.witty.games",
    "productName": "Witty Styzes & Games",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  },
  "dependencies": {
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "electron": "20.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}
